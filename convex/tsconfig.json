{
  /* Scopes the Convex backend for the Convex CLI's typecheck. The Next app's
     tsconfig excludes `convex/`, and this one excludes the app, so each side
     typechecks against its own runtime. Generated by convention; kept in sync
     with `npx convex dev`. */
  "compilerOptions": {
    "allowJs": true,
    "strict": true,
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "module": "ESNext",
    "target": "ESNext",
    "lib": ["ES2021", "dom"],
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": ["./**/*"],
  "exclude": ["./_generated"]
}
