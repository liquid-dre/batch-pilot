# Convex (ROADMAP §5 / §9 — the database seam).
# `npx convex dev` writes these into .env.local for you; this file documents them.
#
# Public deployment URL the browser client connects to (realtime queries).
NEXT_PUBLIC_CONVEX_URL=

# Written by `npx convex dev` — the deployment the CLI pushes functions to.
# CONVEX_DEPLOYMENT=

# Convex Auth (@convex-dev/auth) — set ON THE DEPLOYMENT (not here) by running
# `npx @convex-dev/auth`, which generates JWT_PRIVATE_KEY, JWKS and SITE_URL.
# Nothing extra is needed in this file for email + password auth.
